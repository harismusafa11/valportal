# ValPortal.NET - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub

# --- Supabase (Frontend) ---------------------------------------------------
# Public URL of your Supabase project
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Publishable (anon) key - safe to expose in frontend
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# --- Supabase (Server-side only) ------------------------------------------
# WARNING: NEVER expose this in frontend code or commit to GitHub
# Only used in server.js / api/index.js (Vercel serverless functions)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
